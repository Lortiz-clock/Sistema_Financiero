@model IEnumerable<Sistema_Financiero.Models.RegionModelo>

@{
    ViewData["Title"] = "Lista de Regiones";
}

<style>
    .table-container {
        width: 100%;
        background: #ffffff;
        padding: 16px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        margin-top: 20px;
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
        font-size: 13px;
        color: #2d3748;
    }

        .custom-table thead tr {
            background-color: #f8f9fa;
            color: #4a5568;
            font-weight: 600;
            border-bottom: 2px solid #edf2f7;
        }

        .custom-table th, .custom-table td {
            padding: 12px 14px;
            vertical-align: middle;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid #edf2f7;
            transition: background-color 0.15s ease;
        }

            .custom-table tbody tr:hover {
                background-color: #f7fafc;
            }

    .text-nowrap {
        white-space: nowrap;
    }

    .btn-accion {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .btn-editar {
        background-color: #ebf8ff;
        color: #2b6cb0;
    }

    .btn-eliminar {
        background-color: #ffeeee;
        color: #e53e3e;
        margin-left: 5px;
    }

    .btn-nuevo {
        background-color: #1e40af;
        color: white;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }

    .search-box {
        display: inline-flex;
        align-items: center;
        background: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 4px 10px;
        width: 100%;
        max-width: 320px;
    }

    .search-input {
        border: none;
        outline: none;
        padding: 4px;
        font-size: 13px;
        color: #2d3748;
        width: 100%;
    }

    .search-btn {
        background: none;
        border: none;
        color: #1e40af;
        cursor: pointer;
        padding: 0 5px;
    }

    .btn-clear {
        color: #e53e3e;
        text-decoration: none;
        font-size: 11px;
        margin-left: 5px;
    }
</style>

<h2 style="font-family:'Segoe UI',sans-serif;color:#2d3748;font-weight:600;margin-bottom:5px;">Lista de Regiones</h2>
<p style="color:#718096;margin-bottom:20px;">Gestión de zonas geográficas y regiones del sistema.</p>

<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 15px; gap: 15px;">
    <div>
        @if (User.IsInRole("Administrador"))
        {
            <a href="@Url.Action("Crear", "Region")" class="btn-nuevo">
                <i class="fa-solid fa-plus"></i> Nueva Región
            </a>
        }
    </div>

    <form action="@Url.Action("Index", "Region")" method="GET" style="margin: 0; display: flex; align-items: center;">
        <div class="search-box">
            <input type="text" name="buscarNombre" class="search-input" placeholder="Buscar región por nombre..." value="@ViewBag.BusquedaActual" />
            <button type="submit" class="search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual))
        {
            <a href="@Url.Action("Index", "Region")" class="btn-clear" title="Limpiar búsqueda">
                <i class="fa-solid fa-circle-xmark"></i> Limpiar
            </a>
        }
    </form>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div style="background-color: #e6fffa; color: #00a389; padding: 10px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 15px; font-family: 'Segoe UI', sans-serif;">
        <i class="fa-solid fa-circle-check"></i> @TempData["MensajeExito"]
    </div>
}

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>Código</th>
                <th>Nombre de la Región</th>
                @if (User.IsInRole("Administrador"))
                {
                    <th style="width: 200px;">Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="3" style="text-align: center; color: #a0aec0; padding: 20px;">No se encontraron regiones.</td>
                </tr>
            }
            else
            {
                @foreach (var reg in Model)
                {
                    <tr>
                        <td><strong>@reg.CodigoRegion</strong></td>
                        <td><span style="font-weight: 600; color: #1a202c;">@reg.Nombre</span></td>
                        
                        @if (User.IsInRole("Administrador"))
                        {
                            <td class="text-nowrap">
                                <a href="@Url.Action("Editar", "Region", new { id = reg.CodigoRegion })" class="btn-accion btn-editar">
                                    <i class="fa-solid fa-pen"></i> Editar
                                </a>
                                
                                <form action="@Url.Action("Eliminar", "Region", new { id = reg.CodigoRegion })" method="POST" style="display:inline;" onsubmit="return confirm('¿Estás seguro de eliminar esta región?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-accion btn-eliminar">
                                        <i class="fa-solid fa-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
</div>