@model Sistema_Financiero.Models.UsuarioModelo

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<style>
    .form-card {
        background: var(--color-background-primary, #ffffff);
        border: 0.5px solid var(--color-border-tertiary, #e2e8f0);
        border-radius: 12px;
        padding: 1.5rem;
        max-width: 560px;
        margin-top: 1rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group.full {
            grid-column: 1 / -1;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 500;
            color: #475569;
        }

    .form-control {
        width: 100%;
        padding: 9px 12px;
        border: 0.5px solid #cbd5e1;
        border-radius: 8px;
        font-size: 14px;
        box-sizing: border-box;
        outline: none;
        font-family: 'Segoe UI', sans-serif;
        background: #ffffff;
        color: #1a202c;
    }

        .form-control:focus {
            border-color: #2b6cb0;
            box-shadow: 0 0 0 3px rgba(43,108,176,0.12);
        }

    .section-label {
        grid-column: 1 / -1;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #a0aec0;
        margin-bottom: -0.25rem;
    }

    .form-divider {
        grid-column: 1 / -1;
        border: none;
        border-top: 0.5px solid #edf2f7;
        margin: 0.25rem 0;
    }

    .btn-guardar {
        background: #1e40af;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-cancelar {
        background: transparent;
        color: #475569;
        border: 0.5px solid #cbd5e1;
        padding: 9px 22px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-left: 8px;
    }

    .required {
        color: #e53e3e;
        margin-left: 2px;
    }
</style>

<h2 style="font-family:'Segoe UI',sans-serif;color:#2d3748;font-weight:600;margin-bottom:4px;">
    Nuevo Usuario
</h2>
<p style="color:#718096;margin-bottom:1.25rem;">
    Completá los datos para registrar un nuevo acceso al sistema.
</p>

@if (ViewBag.Error != null)
{
    <div style="background:#ffeeee;color:#e53e3e;padding:10px 14px;border-radius:8px;font-size:13px;font-weight:600;margin-bottom:1rem;max-width:560px;">
        <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error
    </div>
}

<div class="form-card">
    <form action="@Url.Action("Crear", "Usuarios")" method="POST">

        <div class="form-grid">

            <div class="section-label">Asignación de Empleado</div>

            <div class="form-group full">
                <label>Seleccionar Empleado <span class="required">*</span></label>
                <select name="CodigoEmpleado" class="form-control" required>
                    <option value="">— Seleccioná un empleado —</option>
                    @if (ViewBag.Empleados != null)
                    {
                        @foreach (var emp in (List<Sistema_Financiero.Models.EmpleadosModelo>)ViewBag.Empleados)
                        {
                            <option value="@emp.CodigoEmpleado">@emp.Nombre</option>
                        }
                    }
                </select>
            </div>

            <hr class="form-divider" />

            <div class="section-label">Credenciales de Acceso</div>

            <div class="form-group">
                <label>Nombre de Usuario <span class="required">*</span></label>
                <input type="text" name="Nombre" class="form-control"
                       placeholder="ej: j.perez" required />
            </div>

            <div class="form-group">
                <label>Contraseña <span class="required">*</span></label>
                <input type="password" name="Clave" class="form-control"
                       placeholder="••••••••" required />
            </div>

            <hr class="form-divider" />

            <div class="section-label">Permisos y Estado</div>

            <div class="form-group">
                <label>Rol asignado <span class="required">*</span></label>
                <select name="CodigoRol" class="form-control" required>
                    <option value="">— Seleccioná un rol —</option>
                    @if (ViewBag.Roles != null)
                    {
                        @foreach (var rol in (List<Sistema_Financiero.Models.RolModelo>)ViewBag.Roles)
                        {
                            <option value="@rol.CodigoRol">@rol.Nombre</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Estado <span class="required">*</span></label>
                <select name="Estado" class="form-control">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>

            <hr class="form-divider" />

            <div style="grid-column: 1 / -1;">
                <button type="submit" class="btn-guardar">Guardar</button>
                <a href="@Url.Action("Index", "Usuarios")" class="btn-cancelar">Cancelar</a>
            </div>

        </div>
    </form>
</div>