@model Sistema_Financiero.Models.EmpleadosModelo

@{
    ViewData["Title"] = "Editar Empleado";
}

<style>
    .form-card {
        background: var(--color-background-primary, #ffffff);
        border: 0.5px solid var(--color-border-tertiary, #e2e8f0);
        border-radius: 12px;
        padding: 1.5rem;
        max-width: 560px;
        margin-top: 1rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group.full {
            grid-column: 1 / -1;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 500;
            color: #475569;
        }

    .form-control {
        width: 100%;
        padding: 9px 12px;
        border: 0.5px solid #cbd5e1;
        border-radius: 8px;
        font-size: 14px;
        box-sizing: border-box;
        outline: none;
        font-family: 'Segoe UI', sans-serif;
        background: #ffffff;
        color: #1a202c;
    }

        .form-control:focus {
            border-color: #2b6cb0;
            box-shadow: 0 0 0 3px rgba(43,108,176,0.12);
        }

    .section-label {
        grid-column: 1 / -1;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #a0aec0;
        margin-bottom: -0.25rem;
    }

    .form-divider {
        grid-column: 1 / -1;
        border: none;
        border-top: 0.5px solid #edf2f7;
        margin: 0.25rem 0;
    }

    .btn-guardar {
        background: #1e40af;
        color: white;
        border: none;
        padding: 9px 22px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-cancelar {
        background: transparent;
        color: #475569;
        border: 0.5px solid #cbd5e1;
        padding: 9px 22px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-left: 8px;
    }

    .required {
        color: #e53e3e;
        margin-left: 2px;
    }
</style>

<h2 style="font-family:'Segoe UI',sans-serif;color:#2d3748;font-weight:600;margin-bottom:4px;">
    Editar Empleado
</h2>
<p style="color:#718096;margin-bottom:1.25rem;">
    Modificá los datos del empleado seleccionado en la nómina.
</p>

@if (ViewBag.Error != null)
{
    <div style="background:#ffeeee;color:#e53e3e;padding:10px 14px;border-radius:8px;font-size:13px;font-weight:600;margin-bottom:1rem;max-width:560px;">
        <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error
    </div>
}

<div class="form-card">
    <form action="@Url.Action("Editar", "Empleados")" method="POST">

        <input type="hidden" name="CodigoEmpleado" value="@Model.CodigoEmpleado" />

        <div class="form-grid">

            <div class="section-label">Asignación</div>

            <div class="form-group full">
                <label>Sucursal <span class="required">*</span></label>
                <select name="CodigoSucursal" class="form-control" required>
                    <option value="">— Seleccioná una sucursal —</option>
                    @if (ViewBag.Sucursales != null)
                    {
                        @foreach (var s in ViewBag.Sucursales)
                        {
                            <option value="@s.CodigoSucursal" selected="@(s.CodigoSucursal == Model.CodigoSucursal)">
                                @s.Nombre
                            </option>
                        }
                    }
                </select>
            </div>

            <hr class="form-divider" />

            <div class="section-label">Datos personales</div>

            <div class="form-group full">
                <label>Nombre completo <span class="required">*</span></label>
                <input type="text" name="Nombre" class="form-control" value="@Model.Nombre" required />
            </div>

            <div class="form-group">
                <label>Teléfono <span class="required">*</span></label>
                <input type="text" name="Telefono" class="form-control" value="@Model.Telefono" required />
            </div>

            <div class="form-group">
                <label>Fecha de nacimiento <span class="required">*</span></label>
                <input type="date" name="FechaNacimiento" class="form-control" value="@Model.FechaNacimiento.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="form-group full">
                <label>Dirección</label>
                <input type="text" name="Direccion" class="form-control" value="@Model.Direccion" placeholder="Dirección residencial (opcional)" />
            </div>

            <hr class="form-divider" />

            <div class="section-label">Datos laborales</div>

            <div class="form-group">
                <label>Cargo <span class="required">*</span></label>
                <input type="text" name="Cargo" class="form-control" value="@Model.Cargo" required />
            </div>

            <div class="form-group">
                <label>Fecha de entrada <span class="required">*</span></label>
                <input type="date" name="FechaEntrada" class="form-control" value="@Model.FechaEntrada.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="form-group">
                <label>Estado <span class="required">*</span></label>
                <select name="Estado" class="form-control">
                    <option value="true" selected="@(Model.Estado == true)">Activo</option>
                    <option value="false" selected="@(Model.Estado == false)">Inactivo</option>
                </select>
            </div>

            <hr class="form-divider" />

            <div style="grid-column: 1 / -1;">
                <button type="submit" class="btn-guardar">Guardar Cambios</button>
                <a href="@Url.Action("Index", "Empleados")" class="btn-cancelar">Cancelar</a>
            </div>

        </div>
    </form>
</div>