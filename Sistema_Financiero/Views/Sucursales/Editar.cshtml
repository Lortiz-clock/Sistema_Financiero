@model Sistema_Financiero.Models.SucursalesModelo

@{
    ViewData["Title"] = "Editar Sucursal";
}

<style>
    /* Mismos estilos para mantener la coherencia visual */
    .form-container {
        background: #ffffff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        max-width: 500px;
        margin-top: 20px;
    }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; margin-bottom: 6px; color: #475569; font-size: 0.85rem; font-weight: 500; }
    .form-control { width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 0.95rem; box-sizing: border-box; outline: none; }
    .form-control:focus { border-color: #2b6cb0; box-shadow: 0 0 0 4px rgba(43,108,176,0.1); }
    .btn-guardar { background: #1e40af; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 0.95rem; font-weight: 600; cursor: pointer; }
    .btn-cancelar { background: #f1f5f9; color: #475569; border: none; padding: 10px 24px; border-radius: 8px; font-size: 0.95rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; margin-left: 10px; }
</style>

<h2 style="font-family:'Segoe UI',sans-serif;color:#2d3748;font-weight:600;margin-bottom:5px;">Editar Sucursal</h2>
<p style="color:#718096;margin-bottom:20px;">Modificá los datos de la sucursal seleccionada.</p>

@if (ViewBag.Error != null)
{
    <div style="background-color: #ffeeee; color: #e53e3e; padding: 10px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 15px;">
        @ViewBag.Error
    </div>
}

<div class="form-container">
    <form action="@Url.Action("Editar", "Sucursales")" method="POST">

        <input type="hidden" name="CodigoSucursal" value="@Model.CodigoSucursal" />

        <div class="form-group">
            <label>Código de Municipio</label>
            <input type="number" name="CodigoMunicipio" class="form-control" value="@Model.CodigoMunicipio" required />
        </div>

        <div class="form-group">
            <label>Nombre de la Sucursal</label>
            <input type="text" name="Nombre" class="form-control" value="@Model.Nombre" required />
        </div>

        <div class="form-group">
            <label>Teléfono</label>
            <input type="text" name="Telefono" class="form-control" value="@Model.Telefono" required />
        </div>

        <div class="form-group">
            <label>Dirección</label>
            <input type="text" name="Direccion" class="form-control" value="@Model.Direccion" required />
        </div>

        <div class="form-group">
            <label>Estado</label>
            <select name="Estado" class="form-control">
                @if (Model.Estado ?? false)
                {
                    <option value="true" selected>Activo</option>
                    <option value="false">Inactivo</option>
                }
                else
                {
                    <option value="true">Activo</option>
                    <option value="false" selected>Inactivo</option>
                }
            </select>
        </div>

        <button type="submit" class="btn-guardar">Guardar Cambios</button>
        <a href="@Url.Action("Index", "Sucursales")" class="btn-cancelar">Cancelar</a>
    </form>
</div>