@model IEnumerable<Sistema_Financiero.Models.ClientesModelo>

@{
    ViewData["Title"] = "Lista de Clientes";
}

<style>
    .table-container { width: 100%; background: #ffffff; padding: 16px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.04); margin-top: 20px; overflow-x: auto; }
    .custom-table { width: 100%; border-collapse: collapse; font-family: 'Segoe UI', sans-serif; font-size: 13px; color: #2d3748; }
    .custom-table thead tr { background-color: #f8f9fa; color: #4a5568; font-weight: 600; border-bottom: 2px solid #edf2f7; }
    .custom-table th, .custom-table td { padding: 12px 14px; vertical-align: middle; }
    .custom-table tbody tr { border-bottom: 1px solid #edf2f7; transition: background-color 0.15s ease; }
    .custom-table tbody tr:hover { background-color: #f7fafc; }
    .text-nowrap { white-space: nowrap; }
    .badge { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; display: inline-block; text-transform: uppercase; }
    .badge-tipo { background-color: #e2e8f0; color: #475569; }
    .btn-accion { padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 600; border: none; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
    .btn-editar { background-color: #ebf8ff; color: #2b6cb0; }
    .btn-eliminar { background-color: #ffeeee; color: #e53e3e; margin-left: 5px; }
    .btn-nuevo { background-color: #1e40af; color: white; padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; display: inline-block; }
    .search-box { display: inline-flex; align-items: center; background: #ffffff; border: 1px solid #cbd5e1; border-radius: 8px; padding: 4px 10px; width: 100%; max-width: 320px; }
    .search-input { border: none; outline: none; padding: 4px; font-size: 13px; color: #2d3748; width: 100%; }
    .search-btn { background: none; border: none; color: #1e40af; cursor: pointer; padding: 0 5px; }
    .btn-clear { color: #e53e3e; text-decoration: none; font-size: 11px; margin-left: 5px; }
    .subtext { font-size: 11px; color: #718096; margin-top: 2px; display: block; }
</style>

<h2 style="font-family:'Segoe UI',sans-serif;color:#2d3748;font-weight:600;margin-bottom:5px;">Lista de Clientes</h2>
<p style="color:#718096;margin-bottom:20px;">Gestión y control de los clientes del sistema financiero.</p>

<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-bottom: 15px; gap: 15px;">
    <div>
        @* SOLO EL ADMINISTRADOR PUEDE VER EL BOTÓN DE AGREGAR *@
        @if (User.IsInRole("Administrador"))
        {
            <a href="@Url.Action("Agregar", "Clientes")" class="btn-nuevo">
                <i class="fa-solid fa-plus"></i> Nuevo Cliente
            </a>
        }
    </div>

    <form action="@Url.Action("Index", "Clientes")" method="GET" style="margin: 0; display: flex; align-items: center;">
        <div class="search-box">
            <input type="text" name="buscarNombre" class="search-input" placeholder="Buscar cliente por nombre..." value="@ViewBag.BusquedaActual" />
            <button type="submit" class="search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual))
        {
            <a href="@Url.Action("Index", "Clientes")" class="btn-clear" title="Limpiar búsqueda">
                <i class="fa-solid fa-circle-xmark"></i> Limpiar
            </a>
        }
    </form>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div style="background-color: #e6fffa; color: #00a389; padding: 10px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 15px; font-family: 'Segoe UI', sans-serif;">
        <i class="fa-solid fa-circle-check"></i> @TempData["MensajeExito"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background-color: #ffeeee; color: #e53e3e; padding: 10px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 15px; font-family: 'Segoe UI', sans-serif;">
        <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
    </div>
}

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>Código ID</th>
                <th>Nombre / Dirección</th>
                <th>Identificación (DPI / NIT)</th>
                <th>Contacto</th>
                <th>Tipo</th>
                @* SOLO EL ADMINISTRADOR VE LA COLUMNA DE ACCIONES *@
                @if (User.IsInRole("Administrador"))
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="@(User.IsInRole("Administrador") ? "6" : "5")" style="text-align: center; color: #a0aec0; padding: 20px;">
                        No se encontraron clientes registrados.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var cli in Model)
                {
                    <tr>
                        <td><strong>@cli.CodigoCliente</strong></td>
                        <td class="text-nowrap">
                            <span style="font-weight: 600; color: #1a202c;">@cli.Nombre</span>
                            <span class="subtext">
                                <i class="fa-solid fa-location-dot" style="font-size: 10px; color: #a0aec0;"></i> @cli.Direccion
                            </span>
                        </td>
                        <td>
                            <span class="subtext"><strong>DPI:</strong> @cli.DPI</span>
                            <span class="subtext"><strong>NIT:</strong> @cli.NIT</span>
                        </td>
                        <td>
                            <span class="subtext"><i class="fa-solid fa-phone"></i> @cli.Telefono</span>
                            <span class="subtext"><i class="fa-solid fa-envelope"></i> @cli.Correo</span>
                        </td>
                        <td>
                            <span class="badge badge-tipo">@cli.Tipo</span>
                        </td>
                        
                        @* SOLO EL ADMINISTRADOR VE Y EJECUTA LAS ACCIONES *@
                        @if (User.IsInRole("Administrador"))
                        {
                            <td class="text-nowrap">
                                <a href="@Url.Action("Editar", "Clientes", new { id = cli.CodigoCliente })" class="btn-accion btn-editar">
                                    <i class="fa-solid fa-pen"></i> Editar
                                </a>
                                
                                <form action="@Url.Action("Eliminar", "Clientes", new { id = cli.CodigoCliente })" method="POST" style="display:inline;" onsubmit="return confirm('¿Estás seguro de eliminar este cliente?')">
                                    <button type="submit" class="btn-accion btn-eliminar">
                                        <i class="fa-solid fa-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
</div>