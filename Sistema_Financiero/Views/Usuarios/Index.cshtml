@model List<Sistema_Financiero.Models.UsuarioModelo>

@{
    ViewData["Title"] = "Lista de Usuarios";
}

<style>
    .table-container {
        width: 100%;
        background: #ffffff;
        padding: 16px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        margin-top: 20px;
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
        font-size: 13px;
        color: #2d3748;
    }

        .custom-table thead tr {
            background-color: #f8f9fa;
            color: #4a5568;
            font-weight: 600;
            border-bottom: 2px solid #edf2f7;
        }

        .custom-table th, .custom-table td {
            padding: 10px 12px;
            vertical-align: middle;
        }

        .custom-table tbody tr {
            border-bottom: 1px solid #edf2f7;
            transition: background-color 0.15s ease;
        }

            .custom-table tbody tr:hover {
                background-color: #f7fafc;
            }

    .text-nowrap {
        white-space: nowrap;
    }

    .badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
        text-transform: uppercase;
    }

    .badge-activo {
        background-color: #e6fffa;
        color: #00a389;
    }

    .badge-inactivo {
        background-color: #ffeeee;
        color: #e53e3e;
    }

    .btn-accion {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-editar {
        background-color: #ebf8ff;
        color: #2b6cb0;
    }

    .btn-eliminar {
        background-color: #ffeeee;
        color: #e53e3e;
    }

    .btn-nuevo {
        background-color: #1e40af;
        color: white;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 15px;
    }
</style>

<h2 style="font-family:'Segoe UI',sans-serif;color:#2d3748;font-weight:600;margin-bottom:5px;">
    Lista de Usuarios
</h2>
<p style="color:#718096;margin-bottom:20px;">Gestión de accesos y roles del sistema.</p>

@if (User.IsInRole("Administrador"))
{
    <a href="@Url.Action("Crear", "Usuarios")" class="btn-nuevo">
        <i class="fa-solid fa-plus"></i> Nuevo Usuario
    </a>
}

@if (ViewBag.Error != null)
{
    <div class="alert-danger" style="margin-bottom:15px;">@ViewBag.Error</div>
}

<div class="table-container">
    <table class="custom-table">
        <thead>
            <tr>
                <th>Código</th>
                <th>Empleado</th>
                <th>Usuario</th>
                <th>Rol</th>
                <th>Estado</th>
                @if (User.IsInRole("Administrador"))
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td><strong>@u.CodigoUsuario</strong></td>
                    <td class="text-nowrap">@u.NombreEmpleado</td>
                    <td>@u.NombreUsuario</td>
                    <td>@u.NombreRol</td>
                    <td>
                        @if (u.Estado)
                        {
                            <span class="badge badge-activo">Activo</span>
                        }
                        else
                        {
                            <span class="badge badge-inactivo">Inactivo</span>
                        }
                    </td>
                    @if (User.IsInRole("Administrador"))
                    {
                        <td class="text-nowrap">
                            <a href="@Url.Action("Editar", "Usuarios", new { id = u.CodigoUsuario })" class="btn-accion btn-editar">
                                <i class="fa-solid fa-pen"></i> Editar
                            </a>
                            <a href="@Url.Action("Eliminar", "Usuarios", new { id = u.CodigoUsuario })"
                               class="btn-accion btn-eliminar"
                               onclick="return confirm('¿Estás seguro de eliminar este usuario?')">
                                <i class="fa-solid fa-trash"></i> Eliminar
                            </a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>